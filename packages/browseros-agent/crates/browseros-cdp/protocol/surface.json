        "activateWindow",
        "addTabsToGroup",
        "close",
        "closeTab",
        "closeTabGroup",
        "closeWindow",
        "createTab",
        "createTabGroup",
        "createWindow",
        "getActiveTab",
        "getActiveWindow",
        "getTabGroups",
        "getTabInfo",
        "getTabs",
        "getVersion",
        "getWindows",
        "moveTab",
        "removeTabsFromGroup",
        "setWindowVisibility",
        "showTab",
        "updateTabGroup"
      ]
    },
    {
      "domain": "DOM",
      "types": ["BoxModel", "Node"],
      "commands": [
        "describeNode",
        "enable",
